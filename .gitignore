# Claude local permissions
.claude/

# Python
__pycache__/
*.py[cod]

# Package init (contains secrets — copy from __init__.py.example)
__init__.py
!**/__init__.py.example

# Windows
desktop.ini

# Audio source files — exclude all MP3s except the examples folder
*.mp3
!examples/*.mp3

