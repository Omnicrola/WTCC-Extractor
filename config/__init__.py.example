"""
Shared configuration for the WTCC extraction pipeline.

SETUP:
    Copy this file to config/__init__.py and fill in your values:
        cp config/__init__.py.example config/__init__.py

    Alternatively, sensitive values can be set as environment variables
    instead of editing this file directly (see comments below).
"""

import os

# Project root — parent of this config/ directory
BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))

# --- Paths ---
SOURCE_AUDIO_DIR = os.path.join(BASE_DIR, "source_audio")
SEGMENTS_DIR     = os.path.join(BASE_DIR, "segments")
TRANSCRIPTS_DIR  = os.path.join(BASE_DIR, "transcripts")

GAME_INTRO_WAV = os.path.join(BASE_DIR, "resources", "wtcc_intro_fingerprint.wav")
FINGERPRINT_DB = os.path.join(BASE_DIR, "resources", "wtcc_fingerprint.db")
SQLITE_DB      = os.path.join(BASE_DIR, "output", "wtcc.db")
LOGS_DIR       = os.path.join(BASE_DIR, "output", "logs")

# Path to audfprint.py — clone from https://github.com/dpwe/audfprint
# and set this to the full path of audfprint.py
AUDFPRINT_PY = os.path.join(BASE_DIR, "audfprint", "audfprint.py")

# --- Audio extraction ---
# How many seconds after the game intro to extract (game is unlikely >30 min)
SEGMENT_WINDOW_SECONDS = 1800  # 30 minutes

# --- WhisperX ---
WHISPER_MODEL        = "large-v2"
WHISPER_DEVICE       = "cuda"     # "cuda" or "cpu"
WHISPER_COMPUTE_TYPE = "float16"  # "float16" (GPU) or "int8" (CPU)
WHISPER_BATCH_SIZE   = 16

# Unknown speaker clips are saved here by the identify_speakers.py utility
UNKNOWN_SPEAKERS_DIR = os.path.join(BASE_DIR, "output", "unknown_speakers")

# --- Speaker identification (optional) ---
# Drop named .wav clips into this folder to enable automatic speaker labelling.
# Filename format:  Name_anything.wav  (everything before the first '_' becomes the label)
# Multiple clips per person are averaged into a single reference embedding.
# Set to None (or leave the folder empty) to skip and keep generic SPEAKER_XX labels.
SPEAKER_PROFILES_DIR        = os.path.join(BASE_DIR, "resources", "speaker_profiles")
SPEAKER_SIMILARITY_THRESHOLD = 0.75  # cosine similarity [0-1]; below this keeps SPEAKER_XX

# HuggingFace token — required for pyannote speaker diarization.
# 1. Create a token at https://huggingface.co/settings/tokens
# 2. Accept the pyannote model terms at:
#    https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Either paste your token below or set the HF_TOKEN environment variable.
HF_TOKEN = os.environ.get("HF_TOKEN", "YOUR_HF_TOKEN_HERE")

# --- LM Studio / LLM ---
# 1. Download LM Studio: https://lmstudio.ai
# 2. Load a model (Qwen3 8B+ recommended for best results)
# 3. Go to the "Local Server" tab, set context length to at least 40960, and click Start Server
LMSTUDIO_BASE_URL = "http://localhost:1234/v1"
LMSTUDIO_API_KEY  = "lm-studio"   # LM Studio ignores this but the client requires it

# --- audfprint fingerprinting ---
AUDFPRINT_DENSITY = 100
AUDFPRINT_SHIFTS  = 4
